@startuml diagrama_clases
skinparam classAttributeIconSize 0
skinparam classFontSize 13
skinparam classBackgroundColor #F0F8FF
skinparam classBorderColor #4A90D9
skinparam stereotypeCBackgroundColor #D6EAF8
skinparam arrowColor #2E86C1
skinparam packageBackgroundColor #EBF5FB

title Apptism — Diagrama de Clases

' ─── ENUMERACIONES ───────────────────────────────────────────

enum RolUsuario {
    NINO
    PADRE
    PROFESOR
    ADMIN
}

enum ZonaHoraria {
    MANANA
    MEDIODIA
    NOCHE
}

enum CategoriaTarea {
    MATEMATICAS
    LENGUA
    ARTE
    JUEGO
    HABITOS
}

enum Emocion {
    FELIZ
    TRISTE
    ENFADADO
    MIEDO
    CALMA
    IRA
}

enum EstadoSolicitud {
    PENDIENTE
    APROBADA
    RECHAZADA
}

enum TipoMensaje {
    EMOCION
    CHAT
}

' ─── ENTIDADES ───────────────────────────────────────────────

class Usuario {
    - Long id
    - String email
    - String password
    - RolUsuario rol
    - String nombre
    - LocalDate fechaNacimiento
    - Integer puntosAcumulados
    - List<Usuario> ninos
    - List<Rutina> rutinas
    - List<Tarea> tareas
}

class Tarea {
    - Long id
    - String titulo
    - String descripcion
    - CategoriaTarea categoria
    - Integer puntosPorCompletar
    - boolean completada
    - LocalDateTime fechaProgramada
    - Usuario nino
    - Usuario creador
}

class Rutina {
    - Long id
    - String nombre
    - ZonaHoraria zonaHoraria
    - String pictogramaUrl
    - boolean completada
    - Integer orden
    - Usuario nino
    - Usuario creador
    - List<PasoRutina> pasos
}

class PasoRutina {
    - Long id
    - String descripcion
    - String pictogramaUrl
    - Integer orden
    - boolean completado
    - Rutina rutina
}

class Recompensa {
    - Long id
    - String descripcion
    - Integer puntosNecesarios
    - String pictogramaUrl
    - boolean activa
    - Usuario familia
}

class SolicitudCanje {
    - Long id
    - EstadoSolicitud estado
    - boolean leida
    - LocalDateTime fecha
    - Usuario nino
    - Recompensa recompensa
}

class RegistroEmocional {
    - Long id
    - Emocion emocion
    - Integer intensidad
    - LocalDateTime fecha
    - Usuario nino
}

class Mensaje {
    - Long id
    - String pictogramaUrl
    - String textoPictograma
    - TipoMensaje tipo
    - boolean leido
    - LocalDateTime fecha
    - Usuario emisor
    - Usuario receptor
}

' ─── SERVICIOS ───────────────────────────────────────────────

class UsuarioService <<Service>> {
    + List<Usuario> findAll()
    + Usuario save(Usuario u)
    + Optional<Usuario> findByEmail(String email)
    + void delete(Long id)
}

class TareaService <<Service>> {
    + List<Tarea> findByNino(Usuario nino)
    + Tarea save(Tarea t)
    + void completar(Long id)
    + void delete(Long id)
}

class RutinaService <<Service>> {
    + List<Rutina> findByNinoAndZona(Usuario nino, ZonaHoraria z)
    + Rutina save(Rutina r)
    + void delete(Long id)
}

class RecompensaService <<Service>> {
    + List<Recompensa> findByFamilia(Usuario familia)
    + Recompensa save(Recompensa r)
    + void toggleActiva(Long id)
}

class SolicitudCanjeService <<Service>> {
    + List<SolicitudCanje> findPendientesByFamilia(Long familiaId)
    + void aprobar(Long id)
    + void rechazar(Long id)
}

class MensajeService <<Service>> {
    + List<Mensaje> findConversacion(Usuario a, Usuario b)
    + Mensaje send(Mensaje m)
    + void marcarLeidos(Long emisorId, Long receptorId)
}

class ArasaacService <<Service>> {
    - ConcurrentHashMap<String, List> cache
    + List buscar(String palabra)
    + List getEmocionesBásicas()
    + String getImagenUrl(int id)
    + void limpiarCache()
}

' ─── RELACIONES ──────────────────────────────────────────────

Usuario "tutor 1" --> "nino 0..*" Usuario : supervisa

Usuario "1" --> "0..*" Tarea : asignada a (nino)
Usuario "1" --> "0..*" Tarea : creada por (creador)
Usuario "1" --> "0..*" Rutina : pertenece a (nino)
Usuario "1" --> "0..*" Rutina : creada por (creador)
Usuario "1" --> "0..*" Recompensa : gestiona (familia)
Usuario "1" --> "0..*" SolicitudCanje : genera (nino)
Usuario "1" --> "0..*" RegistroEmocional : registra (nino)
Usuario "1" --> "0..*" Mensaje : emite
Usuario "1" --> "0..*" Mensaje : recibe

Rutina "1" *-- "1..*" PasoRutina : compuesta de
Recompensa "1" --> "0..*" SolicitudCanje : referenciada en

Tarea ..> CategoriaTarea
Rutina ..> ZonaHoraria
RegistroEmocional ..> Emocion
SolicitudCanje ..> EstadoSolicitud
Mensaje ..> TipoMensaje
Usuario ..> RolUsuario

UsuarioService ..> Usuario
TareaService ..> Tarea
RutinaService ..> Rutina
RecompensaService ..> Recompensa
SolicitudCanjeService ..> SolicitudCanje
MensajeService ..> Mensaje
ArasaacService ..> Mensaje

@enduml
