<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.apptism.controller.AdminController"
            styleClass="root-pane" prefWidth="1280" prefHeight="800">

    <fx:define>
        <ToggleGroup fx:id="grupoRol"/>
    </fx:define>

    <top>
        <HBox styleClass="header" alignment="CENTER_LEFT" spacing="20">
            <padding><Insets top="15" right="25" bottom="15" left="25"/></padding>
            <Label text="Panel de Administración" styleClass="titulo-header"/>
            <HBox HBox.hgrow="ALWAYS"/>
            <Button text="Cerrar sesión" onAction="#onCerrarSesion" styleClass="btn-volver"/>
        </HBox>
    </top>

    <center>
        <TabPane tabClosingPolicy="UNAVAILABLE" styleClass="tab-pane-app">
            <padding><Insets top="15" right="15" bottom="15" left="15"/></padding>

            <Tab text="Crear Usuario">
                <SplitPane dividerPositions="0.42">
                    <padding><Insets top="15" right="0" bottom="0" left="0"/></padding>

                    <VBox spacing="16" styleClass="panel" style="-fx-max-width:480px;">
                        <Label text="Nuevo usuario" styleClass="subtitulo"/>

                        <VBox spacing="6">
                            <Label text="Nombre completo:" styleClass="form-label"/>
                            <TextField fx:id="txtNombre" promptText="Ej: Ana García" styleClass="input-field"/>
                        </VBox>

                        <VBox spacing="6">
                            <Label text="Email:" styleClass="form-label"/>
                            <TextField fx:id="txtEmail" promptText="ana@email.com" styleClass="input-field"/>
                        </VBox>

                        <VBox spacing="6">
                            <Label text="Contraseña:" styleClass="form-label"/>
                            <PasswordField fx:id="txtPassword" promptText="••••••••" styleClass="input-field"/>
                        </VBox>

                        <VBox spacing="6">
                            <Label text="Rol:" styleClass="form-label"/>
                            <HBox spacing="12">
                                <RadioButton fx:id="rbNino" text="Alumno" toggleGroup="$grupoRol"
                                             styleClass="radio-button-form"/>
                                <RadioButton fx:id="rbPadre" text="Padre" toggleGroup="$grupoRol"
                                             styleClass="radio-button-form"/>
                                <RadioButton fx:id="rbProfesor" text="Profesor" toggleGroup="$grupoRol"
                                             styleClass="radio-button-form"/>
                            </HBox>
                        </VBox>

                        <Label fx:id="lblMensaje" text="" styleClass="texto-vacio"/>

                        <Button text="Crear usuario" onAction="#onCrearUsuario"
                                styleClass="btn-accion" maxWidth="Infinity"/>
                    </VBox>

                    <VBox spacing="12" styleClass="panel">
                        <HBox alignment="CENTER_LEFT" spacing="15">
                            <Label text="Usuarios registrados" styleClass="subtitulo"/>
                            <HBox HBox.hgrow="ALWAYS"/>
                            <Button text="Refrescar" onAction="#onRefrescar" styleClass="btn-volver"/>
                        </HBox>

                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <Label text="Ver:" styleClass="form-label"/>
                            <Button text="Todos" onAction="#onVerTodos" styleClass="btn-volver"/>
                            <Button text="Alumnos" onAction="#onVerNinos" styleClass="btn-filtro-alumno"/>
                            <Button text="Padres" onAction="#onVerPadres" styleClass="btn-filtro-padre"/>
                            <Button text="Profes" onAction="#onVerProfesores" styleClass="btn-filtro-profe"/>
                        </HBox>

                        <ListView fx:id="listaUsuarios" VBox.vgrow="ALWAYS"/>

                        <Button text="Eliminar usuario seleccionado" onAction="#onEliminarUsuario"
                                styleClass="btn-eliminar" maxWidth="Infinity"/>
                    </VBox>
                </SplitPane>
            </Tab>

            <Tab text="Vincular Alumno - Tutor">
                <VBox spacing="20" styleClass="panel">
                    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

                    <Label text="Asignar alumno a padre o profesor" styleClass="subtitulo"/>
                    <Label text="Selecciona el tutor y el alumno y pulsa Vincular."
                           styleClass="texto-vacio"/>

                    <HBox spacing="40" alignment="CENTER_LEFT">
                        <VBox spacing="8">
                            <Label text="Tutor (Padre / Profesor):" styleClass="form-label"/>
                            <ComboBox fx:id="cmbTutor" prefWidth="280" styleClass="combo-box"/>
                        </VBox>
                        <VBox spacing="8">
                            <Label text="Alumno:" styleClass="form-label"/>
                            <ComboBox fx:id="cmbNino" prefWidth="280" styleClass="combo-box"/>
                        </VBox>
                    </HBox>

                    <Button text="Vincular alumno a este tutor" onAction="#onVincular"
                            styleClass="btn-accion" prefWidth="320" prefHeight="48"/>

                    <Label fx:id="lblMensajeVinculo" text="" styleClass="texto-vacio"/>

                    <Label text="Vínculos actuales:" styleClass="subtitulo" style="-fx-padding:16px 0 0 0;"/>
                    <ListView fx:id="listaVinculos" VBox.vgrow="ALWAYS"/>
                </VBox>
            </Tab>

        </TabPane>
    </center>
</BorderPane>
