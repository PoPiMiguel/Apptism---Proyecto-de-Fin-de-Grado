<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.apptism.controller.EmocionesController"
            styleClass="root-pane-nino" prefWidth="1280" prefHeight="800">

    <top>
        <HBox styleClass="header-nino" alignment="CENTER_LEFT" spacing="20">
            <padding><Insets top="15" right="25" bottom="15" left="25"/></padding>
            <Label text="¿Cómo me siento?" style="-fx-font-size:24px; -fx-font-weight:bold; -fx-text-fill:#5652A0;"/>
            <HBox HBox.hgrow="ALWAYS"/>
            <ImageView fitHeight="26" preserveRatio="true" styleClass="app-logo">
                <image>
                    <Image url="@../images/apptism_icon.png"/>
                </image>
            </ImageView>
            <Button text="Volver" onAction="#onVolver" styleClass="btn-volver-nino"/>
        </HBox>
    </top>

    <center>
        <StackPane fx:id="rootStack">
            <VBox spacing="20" alignment="TOP_CENTER">
                <padding><Insets top="30" right="40" bottom="30" left="40"/></padding>

                <HBox alignment="CENTER" spacing="15">
                    <Label text="Enviar a:" style="-fx-font-size:16px; -fx-font-weight:bold; -fx-text-fill:#555;"/>
                    <ComboBox fx:id="cmbDestinatario" prefWidth="220"
                              style="-fx-background-radius:12px; -fx-font-size:14px;"/>
                </HBox>

                <Label text="Toca cómo te sientes:" style="-fx-font-size:20px; -fx-font-weight:bold; -fx-text-fill:#8B72D4;"/>

                <ScrollPane fitToWidth="true" style="-fx-background-color:transparent; -fx-border-color:transparent;"
                            VBox.vgrow="ALWAYS">
                    <FlowPane fx:id="panelPictogramas" hgap="20" vgap="20" alignment="CENTER">
                        <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>
                    </FlowPane>
                </ScrollPane>

                <Label fx:id="lblConfirmacion" styleClass="confirmacion-label"
                       text="¡Enviado!" visible="false"
                       style="-fx-alignment:center;" maxWidth="Infinity"/>
            </VBox>
        </StackPane>
    </center>
</BorderPane>
