<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.apptism.controller.ChatController"
            styleClass="root-pane" prefWidth="1280" prefHeight="800">

    <top>
        <HBox styleClass="header" alignment="CENTER_LEFT" spacing="20">
            <padding><Insets top="15" right="25" bottom="15" left="25"/></padding>
            <!-- Icono clicable: navega al dashboard (página principal del perfil) -->
            <ImageView fitHeight="56" preserveRatio="true" styleClass="app-logo"
                           onMouseClicked="#onVolver">
                    <image><Image url="@../images/apptism_icon.png"/></image>
                </ImageView>
            <HBox HBox.hgrow="ALWAYS"/>
            <ComboBox fx:id="cmbInterlocutor" promptText="Selecciona contacto" prefWidth="220"
                      styleClass="combo-box"/>
            <Button text="Volver" onAction="#onVolver" styleClass="btn-volver"/>
        </HBox>
    </top>

    <center>
        <SplitPane dividerPositions="0.55">
            <padding><Insets top="15" right="15" bottom="15" left="15"/></padding>

            <!-- Panel mensajes -->
            <VBox spacing="0" styleClass="panel">
                <Label text="Conversación" styleClass="subtitulo" style="-fx-padding: 0 0 10 0;"/>
                <ScrollPane fx:id="scrollMensajes" fitToWidth="true" VBox.vgrow="ALWAYS"
                            styleClass="scroll-transparente">
                    <VBox fx:id="panelMensajes" spacing="6">
                        <padding><Insets top="5" right="5" bottom="5" left="5"/></padding>
                    </VBox>
                </ScrollPane>
            </VBox>

            <!-- Panel pictogramas -->
            <VBox spacing="12" styleClass="panel">
                <Label text="Enviar pictograma" styleClass="subtitulo"/>
                <HBox spacing="10">
                    <TextField fx:id="txtBuscar" promptText="Buscar..." styleClass="input-field" HBox.hgrow="ALWAYS"/>
                    <Button text="Buscar" onAction="#onBuscar" styleClass="btn-crear"/>
                </HBox>
                <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                            styleClass="scroll-transparente">
                    <FlowPane fx:id="panelPictos" hgap="12" vgap="12"/>
                </ScrollPane>
            </VBox>
        </SplitPane>
    </center>
</BorderPane>
