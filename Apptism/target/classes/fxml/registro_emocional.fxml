<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.chart.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.apptism.controller.RegistroEmocionalController"
            styleClass="root-pane" prefWidth="1280" prefHeight="800">

    <top>
        <HBox styleClass="header" alignment="CENTER_LEFT" spacing="20">
            <padding><Insets top="15" right="25" bottom="15" left="25"/></padding>
            <ImageView fitHeight="56" preserveRatio="true" styleClass="app-logo"
                           onMouseClicked="#onVolver">
                    <image><Image url="@../images/apptism_icon.png"/></image>
                </ImageView>
            <HBox HBox.hgrow="ALWAYS"/>
            <Button text="Volver" onAction="#onVolver" styleClass="btn-volver"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="20">
            <padding><Insets top="20" right="25" bottom="20" left="25"/></padding>

            <HBox alignment="CENTER_LEFT" spacing="15">
                <Label text="Ver emociones de:" styleClass="form-label" style="-fx-font-size:15px;"/>
                <ComboBox fx:id="cmbNino" prefWidth="220" styleClass="combo-box"/>
            </HBox>

            <SplitPane dividerPositions="0.45" VBox.vgrow="ALWAYS">
                <VBox spacing="10" styleClass="panel">
                    <Label text="Emociones recibidas" styleClass="subtitulo"/>
                    <Label fx:id="lblSinMensajes" text="Aún no hay emociones registradas."
                           styleClass="texto-vacio" visible="false"/>
                    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                                styleClass="scroll-transparente">
                        <FlowPane fx:id="panelMensajes" hgap="16" vgap="16"/>
                    </ScrollPane>
                </VBox>

                <VBox spacing="10" styleClass="panel">
                    <Label text="Historial de la semana" styleClass="subtitulo"/>
                    <BarChart fx:id="graficoEmociones" VBox.vgrow="ALWAYS"
                              styleClass="chart-background">
                        <xAxis><CategoryAxis fx:id="ejeX"/></xAxis>
                        <yAxis><NumberAxis fx:id="ejeY"/></yAxis>
                    </BarChart>
                </VBox>
            </SplitPane>
        </VBox>
    </center>
</BorderPane>
