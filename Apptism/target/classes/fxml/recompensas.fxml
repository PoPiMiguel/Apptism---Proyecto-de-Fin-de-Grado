<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.apptism.controller.RecompensasController"
           prefWidth="1280" prefHeight="800">

    <!-- ===== VISTA TUTOR ===== -->
    <BorderPane fx:id="panelTutor" styleClass="root-pane">
        <top>
            <HBox styleClass="header" alignment="CENTER_LEFT" spacing="20">
                <padding><Insets top="15" right="25" bottom="15" left="25"/></padding>
                <!-- Icono clicable: navega al dashboard (página principal del perfil) -->
                <ImageView fitHeight="56" preserveRatio="true" styleClass="app-logo"
                           onMouseClicked="#onVolver" style="-fx-cursor:hand;">
                    <image><Image url="@../images/apptism_icon.png"/></image>
                </ImageView>
                <HBox HBox.hgrow="ALWAYS"/>
                <Label fx:id="lblPuntosDisponibles" styleClass="puntos-label"/>
                <Button text="Volver" onAction="#onVolver" styleClass="btn-volver"/>
            </HBox>
        </top>
        <center>
            <SplitPane dividerPositions="0.65">
                <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
                <VBox spacing="10" styleClass="panel">
                    <Label text="Recompensas creadas" styleClass="subtitulo"/>
                    <ListView fx:id="listaRecompensas" VBox.vgrow="ALWAYS"/>
                </VBox>
                <VBox spacing="15" styleClass="panel">
                    <Label text="Nueva recompensa" styleClass="subtitulo"/>
                    <Label text="Descripción:"/>
                    <TextField fx:id="txtDescripcion" promptText="Ej: Salir al parque" styleClass="input-field"/>
                    <Label text="Puntos necesarios:"/>
                    <Spinner fx:id="spinnerPuntos" maxWidth="Infinity" editable="true"/>
                    <Button text="Crear recompensa" onAction="#onCrearRecompensa"
                            styleClass="btn-crear" maxWidth="Infinity"/>
                </VBox>
            </SplitPane>
        </center>
    </BorderPane>

    <!-- ===== VISTA NIÑO ===== -->
    <StackPane fx:id="rootStackNino" visible="false">
        <BorderPane styleClass="root-pane-nino">
            <top>
                <HBox styleClass="header-nino" alignment="CENTER_LEFT" spacing="20">
                    <padding><Insets top="15" right="25" bottom="15" left="25"/></padding>
                    <!-- Icono clicable a la izquierda: navega al dashboard -->
                    <ImageView fitHeight="56" preserveRatio="true" styleClass="app-logo"
                               onMouseClicked="#onVolver" style="-fx-cursor:hand;">
                        <image><Image url="@../images/apptism_icon.png"/></image>
                    </ImageView>
                    <HBox HBox.hgrow="ALWAYS"/>
                    <Label fx:id="lblPuntosNino" styleClass="puntos-nino" text="0 puntos"/>
                    <Button text="Volver" onAction="#onVolver" styleClass="btn-volver-nino"/>
                </HBox>
            </top>
            <center>
                <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-border-color: transparent;">
                    <FlowPane fx:id="flowRecompensasNino" hgap="22" vgap="22" alignment="CENTER">
                        <padding><Insets top="30" right="30" bottom="30" left="30"/></padding>
                    </FlowPane>
                </ScrollPane>
            </center>
        </BorderPane>
    </StackPane>

</StackPane>
