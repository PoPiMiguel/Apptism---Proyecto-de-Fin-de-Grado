<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.apptism.controller.RutinasController"
           prefWidth="1280" prefHeight="800">

    <BorderPane fx:id="panelTutor" styleClass="root-pane">
        <top>
            <HBox styleClass="header" alignment="CENTER_LEFT" spacing="20">
                <padding><Insets top="15" right="25" bottom="15" left="25"/></padding>
                <ImageView fitHeight="56" preserveRatio="true" styleClass="app-logo"
                           onMouseClicked="#onVolver">
                    <image><Image url="@../images/apptism_icon.png"/></image>
                </ImageView>
                <HBox HBox.hgrow="ALWAYS"/>
                <Button text="Volver" onAction="#onVolver" styleClass="btn-volver"/>
            </HBox>
        </top>
        <center>
            <SplitPane dividerPositions="0.65">
                <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

                <VBox spacing="10" styleClass="panel">
                    <Label text="Rutinas del niño" styleClass="subtitulo"/>
                    <TabPane fx:id="tabZonas" tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS">
                        <Tab text="Mañana"><ListView fx:id="listaManana" VBox.vgrow="ALWAYS"/></Tab>
                        <Tab text="Mediodía"><ListView fx:id="listaMediodia" VBox.vgrow="ALWAYS"/></Tab>
                        <Tab text="Noche"><ListView fx:id="listaNoche" VBox.vgrow="ALWAYS"/></Tab>
                    </TabPane>
                    <Button text="Eliminar rutina seleccionada" onAction="#onEliminarRutina"
                            styleClass="btn-eliminar" maxWidth="Infinity"/>
                </VBox>

                <ScrollPane fitToWidth="true" styleClass="scroll-transparente">
                    <VBox spacing="15" styleClass="panel" VBox.vgrow="ALWAYS">
                        <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>
                        <Label text="Nueva rutina" styleClass="subtitulo"/>
                        <Label text="Nombre:"/>
                        <TextField fx:id="txtNombreRutina" promptText="Ej: Lavarse los dientes"
                                   styleClass="input-field"/>
                        <Label text="Zona horaria:"/>
                        <ComboBox fx:id="cmbZona" maxWidth="Infinity" visibleRowCount="3"/>
                        <Label text="Asignar a niño:" styleClass="form-label"/>
                        <ComboBox fx:id="cmbNinoTutor" promptText="Selecciona un niño"
                                  maxWidth="Infinity" visibleRowCount="4"/>
                        <Label text="Pictograma (busca por palabra clave y pulsa Enter):" styleClass="form-label"/>
                        <HBox spacing="8" alignment="CENTER_LEFT">
                            <TextField fx:id="txtBuscarPicto"
                                       promptText="Ej: lavarse, comer, dormir..."
                                       styleClass="input-field"
                                       onAction="#buscarPictogramas"
                                       HBox.hgrow="ALWAYS"/>
                            <Button text="Buscar" onAction="#buscarPictogramas" styleClass="btn-crear"/>
                        </HBox>
                        <FlowPane fx:id="panelPictosRutina" hgap="8" vgap="8"
                                  prefWrapLength="360" minHeight="80"/>
                        <Button text="Crear rutina" onAction="#onCrearRutina"
                                styleClass="btn-crear" maxWidth="Infinity"/>
                    </VBox>
                </ScrollPane>
            </SplitPane>
        </center>
    </BorderPane>

    <StackPane fx:id="rootStackNino" visible="false">
        <BorderPane styleClass="root-pane-nino">
            <top>
                <HBox styleClass="header-nino" alignment="CENTER_LEFT" spacing="20">
                    <padding><Insets top="15" right="25" bottom="15" left="25"/></padding>
                    <ImageView fitHeight="56" preserveRatio="true" styleClass="app-logo"
                               onMouseClicked="#onVolver">
                        <image><Image url="@../images/apptism_icon.png"/></image>
                    </ImageView>
                    <HBox HBox.hgrow="ALWAYS"/>
                    <Button text="Volver" onAction="#onVolver" styleClass="btn-volver-nino"/>
                </HBox>
            </top>
            <center>
                <ScrollPane fitToWidth="true" styleClass="scroll-transparente">
                    <FlowPane fx:id="flowRutinasNino" hgap="22" vgap="22" alignment="CENTER">
                        <padding><Insets top="30" right="30" bottom="30" left="30"/></padding>
                    </FlowPane>
                </ScrollPane>
            </center>
        </BorderPane>
    </StackPane>

</StackPane>
