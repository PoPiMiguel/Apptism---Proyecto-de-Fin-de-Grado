<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.shape.*?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.apptism.controller.LoginController"
           prefWidth="1280" prefHeight="800"
           styleClass="login-root">

    <Region styleClass="login-background"/>

    <Circle radius="220.0" styleClass="deco-circle-purple"
            translateX="-440.0" translateY="-160.0"/>
    <Circle radius="160.0" styleClass="deco-circle-blue"
            translateX="500.0" translateY="-220.0"/>
    <Circle radius="190.0" styleClass="deco-circle-orange"
            translateX="480.0" translateY="280.0"/>

    <VBox alignment="CENTER" spacing="0" styleClass="login-card"
          maxWidth="360.0" maxHeight="-Infinity"
          StackPane.alignment="CENTER">

        <VBox alignment="CENTER" spacing="6.0" styleClass="login-header-section">
            <StackPane styleClass="login-logo-circle">
                <ImageView fx:id="imgLogo" fitWidth="36.0" fitHeight="36.0"
                           preserveRatio="true"/>
            </StackPane>
            <Label text="Apptism" styleClass="titulo-login"/>
            <Label text="La app para acompañar a tu peque" styleClass="subtitulo-login"/>
        </VBox>

        <VBox spacing="6.0" styleClass="login-field-group">
            <Label text="Correo electrónico" styleClass="login-field-label"/>
            <TextField fx:id="txtEmail" promptText="usuario@email.com" styleClass="input-field"/>
        </VBox>

        <VBox spacing="6.0" styleClass="login-field-group">
            <Label text="Contraseña" styleClass="login-field-label"/>
            <PasswordField fx:id="txtPassword" promptText="••••••••" styleClass="input-field"/>
        </VBox>

        <Label fx:id="lblError" text="" styleClass="error-label" style="-fx-padding: 4 0 0 0;"/>

        <Button text="Entrar →" onAction="#onLogin" styleClass="btn-login-principal"
                maxWidth="Infinity" style="-fx-padding: 13; -fx-background-radius: 14; -fx-font-size: 15;"/>

        <HBox alignment="CENTER" spacing="8.0" styleClass="login-dots-row">
            <Region styleClass="dot-morado"/>
            <Region styleClass="dot-azul"/>
            <Region styleClass="dot-verde"/>
            <Region styleClass="dot-amarillo"/>
            <Region styleClass="dot-naranja"/>
        </HBox>

    </VBox>

</StackPane>
