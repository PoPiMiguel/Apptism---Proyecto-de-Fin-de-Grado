<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.apptism.controller.TareasController"
           prefWidth="1280" prefHeight="800">

    <!-- ===== VISTA TUTOR ===== -->
    <BorderPane fx:id="panelTutor" styleClass="root-pane">
        <top>
            <HBox styleClass="header" alignment="CENTER_LEFT" spacing="20">
                <padding><Insets top="15" right="25" bottom="15" left="25"/></padding>
                <Label text="📚 Tareas" styleClass="titulo-header"/>
                <Label text="(Asigna tareas a los niños)" styleClass="titulo-header"
                       style="-fx-font-size:14px; -fx-text-fill: rgba(255,255,255,0.75);"/>
                <HBox HBox.hgrow="ALWAYS"/>
                <Label fx:id="lblPuntosTotales" styleClass="puntos-label"/>
                <Button text="← Volver" onAction="#onVolver" styleClass="btn-volver"/>
            </HBox>
        </top>
        <center>
            <SplitPane dividerPositions="0.62">
                <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
                <VBox spacing="10" styleClass="panel">
                    <Label text="Tareas asignadas" styleClass="subtitulo"/>
                    <ListView fx:id="listaTareas" VBox.vgrow="ALWAYS"/>
                    <Button text="🗑️ Eliminar seleccionada" onAction="#onEliminarTarea"
                            styleClass="btn-eliminar" maxWidth="Infinity"/>
                </VBox>
                <VBox spacing="15" styleClass="panel">
                    <Label text="➕ Nueva tarea" styleClass="subtitulo"/>
                    <Label text="Título:"/>
                    <TextField fx:id="txtTitulo" promptText="Ej: Tabla del 2" styleClass="input-field"/>
                    <Label text="Asignar a niño:" style="-fx-font-weight:bold; -fx-text-fill:#555;"/>
                    <ComboBox fx:id="cmbNinoTutor" promptText="Selecciona un niño" maxWidth="Infinity"/>
                    <Label text="Categoría:"/>
                    <ComboBox fx:id="cmbCategoria" maxWidth="Infinity"/>
                    <Label text="Puntos:"/>
                    <Spinner fx:id="spinnerPuntos" maxWidth="Infinity" editable="true"/>
                    <Button text="Crear tarea" onAction="#onCrearTarea"
                            styleClass="btn-crear" maxWidth="Infinity"/>
                </VBox>
            </SplitPane>
        </center>
    </BorderPane>

    <!-- ===== VISTA NIÑO ===== -->
    <StackPane fx:id="rootStackNino" visible="false">
        <BorderPane styleClass="root-pane-nino">
            <top>
                <HBox styleClass="header-nino" alignment="CENTER_LEFT" spacing="20">
                    <padding><Insets top="15" right="25" bottom="15" left="25"/></padding>
                    <Label text="📚 Mis Tareas" style="-fx-font-size:24px; -fx-font-weight:bold; -fx-text-fill:#7a4a00;"/>
                    <HBox HBox.hgrow="ALWAYS"/>
                    <Label fx:id="lblPuntosNino" styleClass="puntos-nino" text="🏆 0 puntos"/>
                    <ImageView fitHeight="26" preserveRatio="true" styleClass="app-logo">
                        <image>
                            <Image url="@../images/logo.png"/>
                        </image>
                    </ImageView>
                    <Button text="⬅️ Volver" onAction="#onVolver" styleClass="btn-volver-nino"/>
                </HBox>
            </top>
            <center>
                <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-border-color: transparent;">
                    <FlowPane fx:id="flowTareasNino" hgap="22" vgap="22" alignment="CENTER">
                        <padding><Insets top="30" right="30" bottom="30" left="30"/></padding>
                    </FlowPane>
                </ScrollPane>
            </center>
        </BorderPane>
    </StackPane>

</StackPane>
